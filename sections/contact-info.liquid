{%- doc -%}
  Displays business contact information for Dhatri Women's World.
  Includes phone, email, WhatsApp, address, social links, and business hours.
{%- enddoc -%}

<div
  class="contact-info section-{{ section.id }} color-{{ section.settings.color_scheme }}"
  style="
    padding-block-start: {{ section.settings.padding_top }}px;
    padding-block-end: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="contact-info__container page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="contact-info__heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="contact-info__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    {%- endif -%}

    <div class="contact-info__grid">
      {%- comment -%} Phone {%- endcomment -%}
      {%- if section.settings.phone != blank -%}
        <a href="tel:+91{{ section.settings.phone }}" class="contact-info__card contact-info__card--phone">
          <div class="contact-info__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <div class="contact-info__details">
            <span class="contact-info__label">Phone</span>
            <span class="contact-info__value">+91 {{ section.settings.phone | slice: 0, 5 }} {{ section.settings.phone | slice: 5, 5 }}</span>
          </div>
        </a>
      {%- endif -%}

      {%- comment -%} Email {%- endcomment -%}
      {%- if section.settings.email != blank -%}
        <a href="mailto:{{ section.settings.email }}" class="contact-info__card contact-info__card--email">
          <div class="contact-info__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </div>
          <div class="contact-info__details">
            <span class="contact-info__label">Email</span>
            <span class="contact-info__value">{{ section.settings.email }}</span>
          </div>
        </a>
      {%- endif -%}

      {%- comment -%} WhatsApp {%- endcomment -%}
      {%- if section.settings.whatsapp != blank -%}
        <a href="https://wa.me/91{{ section.settings.whatsapp }}" target="_blank" rel="noopener" class="contact-info__card contact-info__card--whatsapp">
          <div class="contact-info__icon contact-info__icon--whatsapp">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </div>
          <div class="contact-info__details">
            <span class="contact-info__label">WhatsApp</span>
            <span class="contact-info__value">Message us</span>
          </div>
        </a>
      {%- endif -%}

      {%- comment -%} Address {%- endcomment -%}
      {%- if section.settings.address != blank -%}
        <a href="https://maps.google.com/?q={{ section.settings.address | url_encode }}" target="_blank" rel="noopener" class="contact-info__card contact-info__card--address">
          <div class="contact-info__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div class="contact-info__details">
            <span class="contact-info__label">Visit Us</span>
            <span class="contact-info__value">{{ section.settings.address }}</span>
          </div>
        </a>
      {%- endif -%}

      {%- comment -%} Business Hours {%- endcomment -%}
      {%- if section.settings.business_hours != blank -%}
        <div class="contact-info__card contact-info__card--hours">
          <div class="contact-info__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <div class="contact-info__details">
            <span class="contact-info__label">Business Hours</span>
            <span class="contact-info__value">{{ section.settings.business_hours }}</span>
          </div>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Social Links {%- endcomment -%}
    <div class="contact-info__social">
      <h3 class="contact-info__social-title">Follow Us</h3>
      <div class="contact-info__social-links">
        {%- if section.settings.instagram_url != blank -%}
          <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener" class="contact-info__social-link contact-info__social-link--instagram" aria-label="Follow us on Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
            <span>Instagram</span>
          </a>
        {%- endif -%}

        {%- if section.settings.facebook_url != blank -%}
          <a href="{{ section.settings.facebook_url }}" target="_blank" rel="noopener" class="contact-info__social-link contact-info__social-link--facebook" aria-label="Follow us on Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            <span>Facebook</span>
          </a>
        {%- endif -%}

        {%- if section.settings.whatsapp_channel_url != blank -%}
          <a href="{{ section.settings.whatsapp_channel_url }}" target="_blank" rel="noopener" class="contact-info__social-link contact-info__social-link--whatsapp" aria-label="Join our WhatsApp Channel">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            <span>WhatsApp Channel</span>
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .contact-info {
    --contact-accent: #b5838d;
    --contact-accent-light: #f4e8ea;
    --contact-whatsapp: #25D366;
  }

  .contact-info__container {
    max-width: 900px;
    margin-inline: auto;
    padding-inline: var(--page-margin);
  }

  .contact-info__heading {
    text-align: center;
    font-size: var(--font-size--3xl);
    font-weight: 500;
    letter-spacing: -0.02em;
    margin: 0 0 0.3em;
    color: var(--color-foreground);
  }

  .contact-info__subheading {
    text-align: center;
    font-size: var(--font-size--md);
    color: rgb(var(--color-foreground-rgb) / 0.6);
    margin: 0 0 2.5rem;
    line-height: 1.6;
  }

  .contact-info__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  @media screen and (max-width: 749px) {
    .contact-info__grid {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }

  .contact-info__card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 24px;
    border-radius: 14px;
    background: rgb(var(--color-foreground-rgb) / 0.03);
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.08);
    text-decoration: none;
    color: var(--color-foreground);
    transition: all 0.25s ease;
  }

  a.contact-info__card:hover {
    background: rgb(var(--color-foreground-rgb) / 0.06);
    border-color: rgb(var(--color-foreground-rgb) / 0.15);
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgb(var(--color-foreground-rgb) / 0.08);
  }

  .contact-info__card--address {
    grid-column: 1 / -1;
  }

  .contact-info__card--hours {
    grid-column: 1 / -1;
  }

  .contact-info__icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: var(--contact-accent-light);
    color: var(--contact-accent);
  }

  .contact-info__icon--whatsapp {
    background: #e8f8ee;
    color: var(--contact-whatsapp);
  }

  .contact-info__card--whatsapp .contact-info__icon {
    background: #e8f8ee;
    color: var(--contact-whatsapp);
  }

  .contact-info__details {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .contact-info__label {
    font-size: var(--font-size--xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgb(var(--color-foreground-rgb) / 0.5);
    font-weight: 600;
  }

  .contact-info__value {
    font-size: var(--font-size--md);
    color: var(--color-foreground);
    font-weight: 500;
    line-height: 1.5;
    word-break: break-word;
  }

  /* Social Links */
  .contact-info__social {
    margin-block-start: 40px;
    text-align: center;
  }

  .contact-info__social-title {
    font-size: var(--font-size--lg);
    font-weight: 500;
    margin: 0 0 20px;
    color: var(--color-foreground);
  }

  .contact-info__social-links {
    display: flex;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .contact-info__social-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: 100px;
    font-size: var(--font-size--sm);
    font-weight: 500;
    text-decoration: none;
    transition: all 0.25s ease;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
    color: var(--color-foreground);
    background: transparent;
  }

  .contact-info__social-link:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgb(0 0 0 / 0.1);
  }

  .contact-info__social-link--instagram:hover {
    background: linear-gradient(135deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
    color: #fff;
    border-color: transparent;
  }

  .contact-info__social-link--facebook:hover {
    background: #1877F2;
    color: #fff;
    border-color: transparent;
  }

  .contact-info__social-link--whatsapp:hover {
    background: #25D366;
    color: #fff;
    border-color: transparent;
  }

  .contact-info__social-link svg {
    flex-shrink: 0;
  }

  /* Dark mode adjustments */
  @media (prefers-color-scheme: dark) {
    .contact-info__icon {
      background: rgb(var(--color-foreground-rgb) / 0.1);
    }

    .contact-info__card--whatsapp .contact-info__icon {
      background: rgb(37 211 102 / 0.15);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Contact Information",
  "tag": "section",
  "class": "contact-info-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get in Touch"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "We'd love to hear from you. Reach out through any of the channels below."
    },
    {
      "type": "header",
      "content": "Contact Details"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone Number",
      "default": "7396665369"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email Address",
      "default": "support@dhatriww.com"
    },
    {
      "type": "text",
      "id": "whatsapp",
      "label": "WhatsApp Number",
      "default": "7396665369"
    },
    {
      "type": "textarea",
      "id": "address",
      "label": "Address",
      "default": "Indu Aranya Apartments, Nagole, Hyderabad, Telangana, India"
    },
    {
      "type": "text",
      "id": "business_hours",
      "label": "Business Hours",
      "default": "Monday to Saturday · 10:00 AM – 5:00 PM IST"
    },
    {
      "type": "header",
      "content": "Social Links"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL",
      "default": "https://www.instagram.com/dhatri_womensworld/"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL",
      "default": "https://www.facebook.com/people/Dhatri-Womens-World/61590135851833/"
    },
    {
      "type": "url",
      "id": "whatsapp_channel_url",
      "label": "WhatsApp Channel URL",
      "default": "https://www.whatsapp.com/channel/0029VbBvxNL4o7qIUhLuHK2k"
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Contact Information"
    }
  ]
}
{% endschema %}
